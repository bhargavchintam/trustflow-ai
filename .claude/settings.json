{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {"type": "command", "command": ".claude/hooks/precommit-guard.sh"},
          {"type": "command", "command": ".claude/hooks/predeploy-reminder.sh"}
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {"type": "command", "command": ".claude/hooks/postedit-policy-reminder.sh"}
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(pnpm install:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm dev:*)",
      "Bash(pnpm add:*)",
      "Bash(pnpm dlx:*)",
      "Bash(pnpx:*)",
      "Bash(npx:*)",
      "Bash(uv run:*)",
      "Bash(uv add:*)",
      "Bash(uv sync:*)",
      "Bash(uv pip install:*)",
      "Bash(uv init:*)",
      "Bash(uv venv:*)",
      "Bash(pip install:*)",
      "Bash(python -m:*)",
      "Bash(python -c:*)",
      "Bash(python3 -m:*)",
      "Bash(psql:*)",
      "Bash(pg_dump:*)",
      "Bash(pg_isready:*)",
      "Bash(docker build:*)",
      "Bash(docker tag:*)",
      "Bash(docker push:*)",
      "Bash(docker login:*)",
      "Bash(docker run:*)",
      "Bash(docker ps:*)",
      "Bash(docker logs:*)",
      "Bash(docker compose:*)",
      "Bash(docker info)",
      "Bash(aws ecr:*)",
      "Bash(aws apprunner:*)",
      "Bash(aws sts get-caller-identity)",
      "Bash(aws secretsmanager:*)",
      "Bash(aws rds describe-db-instances:*)",
      "Bash(aws iam:*)",
      "Bash(aws logs tail:*)",
      "Bash(aws ec2 describe:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git init)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git remote:*)",
      "Bash(git push:*)",
      "Bash(curl:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(rg:*)",
      "Bash(tree:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(echo:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(which:*)",
      "Bash(node --version)",
      "Bash(python --version)",
      "Bash(python3 --version)",
      "Bash(pnpm --version)"
    ]
  }
}
