{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Backend (FastAPI / uvicorn)",
      "runtimeExecutable": "uv",
      "runtimeArgs": [
        "--directory",
        "backend",
        "run",
        "uvicorn",
        "app.main:app",
        "--reload",
        "--port",
        "8080"
      ],
      "port": 8080
    },
    {
      "name": "Frontend (Next.js dev)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": [
        "--dir",
        "frontend",
        "dev"
      ],
      "port": 3000
    }
  ]
}
