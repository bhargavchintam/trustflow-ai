# Copy to .env and fill in. The .env file is gitignored.

# ===== Required =====

# Anthropic API key (Claude Sonnet 4.6 reasoning + Haiku 4.5 router)
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Voyage embeddings (1024d). Free tier covers seeded data + few hundred queries.
# https://dash.voyageai.com/
VOYAGE_API_KEY=pa-...

# OpenAI fallback (optional — used only if VOYAGE_API_KEY is not set)
# OPENAI_API_KEY=sk-...

# Postgres + pgvector connection string (Supabase / RDS / local — all work).
# Schema: WHERE tenant_id = $1 enforced everywhere. Extensions: vector + pgcrypto.
DATABASE_URL=postgresql://USER:PASS@HOST:5432/DBNAME

# Supabase Auth (used for real sign-up / sign-in flows on top of the same project).
# Get these from Supabase Dashboard -> Project Settings -> API.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=eyJhbG...
SUPABASE_JWT_SECRET=long-random-string-from-API-page
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...   # only needed for /api/seed demo-account creation

# ===== Demo defaults =====

DEFAULT_TENANT_ID=tenant_acme
DEFAULT_USER_ID=sam
LOG_LEVEL=INFO

# Requests with no JWT and no X-Tenant-Id/X-User-Id headers get 401 by default.
# Set true only for local curl-driven debugging (maps them to the demo identity).
ALLOW_ANONYMOUS_IDENTITY=false

# ===== AWS deployment =====

AWS_REGION=us-east-1
# AWS_ACCOUNT_ID=        # numeric, no dashes
# ECR_REPO=trustflow-ai
# APPRUNNER_SERVICE_ARN= # from `aws apprunner describe-service`

# ===== Frontend =====

# Empty = same-origin (recommended after deploy). For split local dev only:
# NEXT_PUBLIC_API_BASE=http://localhost:8080

# ===== Future / production roadmap (not used by current code) =====

# Qdrant Cloud — production split (see README "vector store" section)
# QDRANT_URL=https://xxx.qdrant.cloud
# QDRANT_API_KEY=

# Bedrock Guardrails — defense-in-depth layer (see roadmap)
# BEDROCK_GUARDRAIL_ID=
# BEDROCK_GUARDRAIL_VERSION=
